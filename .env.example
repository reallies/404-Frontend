# ==============================================
# Travel Checklist - 환경변수 템플릿
# ==============================================
# 이 파일은 git에 포함됩니다. 값은 절대 입력하지 마세요.
# 실제 값은 .env.local 파일에 입력하세요.
# 새로운 환경변수가 추가되면 이 파일에도 키를 추가해주세요.
# ==============================================

# ----------------------------------------------
# 앱 기본 설정
# ----------------------------------------------
VITE_APP_NAME=
VITE_APP_ENV=                    # development | staging | production

# ----------------------------------------------
# 백엔드 API
# ----------------------------------------------
VITE_API_BASE_URL=               # ex) http://localhost:8080/api (개발)
                                 # ex) https://api.your-domain.com/api (운영)

# ----------------------------------------------
# Supabase (인증 / DB)
# ----------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ----------------------------------------------
# 분석 도구 (사용자 행동 이벤트 수집)
# 04_meta_okr.md 참고 - 이벤트 수집 구조
# ----------------------------------------------
VITE_ANALYTICS_KEY=              # Mixpanel / Amplitude 등 추후 결정

# ----------------------------------------------
# 기타 외부 서비스 (추후 추가)
# ----------------------------------------------
# VITE_GOOGLE_MAPS_API_KEY=
# VITE_SENTRY_DSN=
